@model AfneyGym.Domain.Entities.Trainer
@{
    ViewData["Title"] = "Eğitmen Düzenle";
}

<div class="mx-auto max-w-4xl rounded-2xl border border-slate-700/60 bg-panel p-6 shadow-2xl shadow-black/30">
    <h4 class="mb-6 text-2xl font-black uppercase text-white"><i class="bi bi-pencil-square mr-2 text-accent"></i>EĞİTMEN <span class="text-accent">DÜZENLE</span></h4>

    <form asp-action="EditTrainer" method="post" enctype="multipart/form-data" class="space-y-5">
        <input type="hidden" asp-for="Id" />
                    
        <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
            <div class="md:col-span-1">
                <label class="mb-2 block text-xs font-semibold uppercase tracking-wide text-slate-400">MEVCUT FOTOĞRAF</label>
                <img src="@Model.ImageUrl" class="h-32 w-32 rounded-xl border-2 border-accent object-cover shadow" alt="Trainer" />
            </div>
            <div class="md:col-span-2 space-y-4">
                <div>
                    <label asp-for="FullName" class="mb-2 block text-xs font-semibold uppercase tracking-wide text-slate-400">AD SOYAD</label>
                    <input asp-for="FullName" class="block w-full rounded-lg border border-slate-600 bg-panelSoft px-3 py-3 text-sm text-white focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/30" />
                    <span asp-validation-for="FullName" class="mt-1 block text-xs text-rose-300"></span>
                </div>
                <div>
                    <label asp-for="Specialty" class="mb-2 block text-xs font-semibold uppercase tracking-wide text-slate-400">UZMANLIK / BRANŞ</label>
                    <select asp-for="Specialty" class="block w-full rounded-lg border border-slate-600 bg-panelSoft px-3 py-3 text-sm text-white focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/30">
                                    <option value="Fitness">Fitness</option>
                                    <option value="Yoga">Yoga</option>
                                    <option value="Pilates">Pilates</option>
                                    <option value="Crossfit">Crossfit</option>
                                    <option value="Boks">Boks</option>
                    </select>
                    <span asp-validation-for="Specialty" class="mt-1 block text-xs text-rose-300"></span>
                </div>
            </div>
        </div>

        <div>
            <label class="mb-2 block text-xs font-semibold uppercase tracking-wide text-slate-400">YENİ FOTOĞRAF (Değiştirmek istemiyorsanız boş bırakın)</label>
            <input type="file" name="imageFile" class="block w-full rounded-lg border border-slate-600 bg-panelSoft px-3 py-3 text-sm text-slate-300 file:mr-4 file:rounded-lg file:border-0 file:bg-accent file:px-4 file:py-2 file:text-sm file:font-semibold file:text-slate-900 hover:file:bg-sky-300" accept="image/*" />
        </div>

        <div>
            <label asp-for="Bio" class="mb-2 block text-xs font-semibold uppercase tracking-wide text-slate-400">BİYOGRAFİ / DENEYİM</label>
            <textarea asp-for="Bio" rows="4" class="block w-full rounded-lg border border-slate-600 bg-panelSoft px-3 py-3 text-sm text-white focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/30"></textarea>
            <span asp-validation-for="Bio" class="mt-1 block text-xs text-rose-300"></span>
        </div>

        <div class="flex gap-3 border-t border-slate-700/60 pt-4">
            <button type="submit" class="inline-flex items-center justify-center rounded-lg bg-accent px-6 py-3 text-sm font-bold text-slate-900 transition hover:bg-sky-300">DEĞİŞİKLİKLERİ KAYDET</button>
            <a asp-action="Trainers" class="inline-flex items-center justify-center rounded-lg border border-slate-500 px-5 py-3 text-sm font-semibold text-slate-200 hover:bg-panelSoft">İPTAL</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}