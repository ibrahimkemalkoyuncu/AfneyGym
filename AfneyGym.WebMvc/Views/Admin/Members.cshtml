@using AfneyGym.Common.Enums
@using AfneyGym.Domain.Entities
@model List<User>
@{
    ViewData["Title"] = "Kullanıcı Yönetimi";
}

<div>
    <div class="mb-5 flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
        <h2 class="text-3xl font-black uppercase tracking-wide">KULLANICI <span class="text-accent">YÖNETİMİ</span></h2>
        <div class="flex flex-col gap-2 sm:flex-row">
            <input type="text" id="memberSearch" class="w-full rounded-lg border border-slate-600 bg-panelSoft px-3 py-2 text-sm text-white placeholder-slate-500 focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/30 sm:w-64" placeholder="Üye ara...">
            <a asp-action="Register" asp-controller="Account" class="inline-flex items-center justify-center gap-2 rounded-lg bg-accent px-4 py-2 text-sm font-semibold text-slate-900 hover:bg-sky-300">
                <i class="bi bi-person-plus-fill"></i> YENİ ÜYE
            </a>
        </div>
    </div>

    <div class="overflow-hidden rounded-2xl border border-slate-700/60 bg-panel shadow-2xl shadow-black/30">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-700/60 text-sm">
                <thead class="bg-panelSoft">
                    <tr class="text-left text-xs uppercase tracking-wide text-slate-400">
                        <th class="px-5 py-3">AD SOYAD</th>
                        <th class="px-5 py-3">E-POSTA</th>
                        <th class="px-5 py-3">ROL</th>
                        <th class="px-5 py-3">KAYIT TARİHİ</th>
                        <th class="px-5 py-3 text-right">İŞLEMLER</th>
                    </tr>
                </thead>
                <tbody id="memberTableBody" class="divide-y divide-slate-800/70">
                    @foreach (var user in Model)
                    {
                        <tr class="hover:bg-slate-800/40">
                            <td class="px-5 py-4">
                                <div class="font-semibold text-white">@user.FirstName @user.LastName</div>
                            </td>
                            <td class="px-5 py-4 text-slate-300">@user.Email</td>
                            <td class="px-5 py-4">
                                @if (user.Role == UserRole.Admin)
                                {
                                    <span class="rounded-full bg-rose-500/20 px-2 py-1 text-xs font-semibold text-rose-300">Yönetici</span>
                                }
                                else if (user.Role == UserRole.Owner)
                                {
                                    <span class="rounded-full bg-amber-500/20 px-2 py-1 text-xs font-semibold text-amber-300">Salon Sahibi</span>
                                }
                                else if (user.Role == UserRole.Staff)
                                {
                                    <span class="rounded-full bg-indigo-500/20 px-2 py-1 text-xs font-semibold text-indigo-300">Personel</span>
                                }
                                else
                                {
                                    <span class="rounded-full bg-slate-600/40 px-2 py-1 text-xs font-semibold text-slate-300">Üye</span>
                                }
                            </td>
                            <td class="px-5 py-4 text-slate-400">@user.CreatedAt.ToString("dd.MM.yyyy")</td>
                            <td class="px-5 py-4">
                                <div class="flex justify-end gap-2">
                                    <a asp-action="MemberDetail" asp-route-id="@user.Id" class="inline-flex h-8 w-8 items-center justify-center rounded-lg border border-emerald-400/50 text-emerald-300 hover:bg-emerald-500/10" title="Detay">
                                        <i class="bi bi-person-lines-fill"></i>
                                    </a>
                                    <a asp-action="EditMember" asp-route-id="@user.Id" class="inline-flex h-8 w-8 items-center justify-center rounded-lg border border-sky-400/50 text-sky-300 hover:bg-sky-500/10" title="Düzenle">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>

                                    <form asp-action="DeleteMember" method="post" onsubmit="return confirmDelete(event, this);">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@user.Id" />
                                        <button type="submit" class="inline-flex h-8 w-8 items-center justify-center rounded-lg border border-rose-400/50 text-rose-300 hover:bg-rose-500/10" title="Sil">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmDelete(event, form) {
            event.preventDefault();
            
            Swal.fire({
                title: 'Emin misiniz?',
                text: "Bu üye sistemden silinecek (IsDeleted = true).",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#e31e24',
                cancelButtonColor: '#333',
                confirmButtonText: 'Evet, Sil!',
                cancelButtonText: 'Vazgeç',
                background: '#111',
                color: '#fff'
            }).then((result) => {
                if (result.isConfirmed) {
                    form.submit();
                }
            });
        }

        document.getElementById('memberSearch').addEventListener('keyup', function() {
            let value = this.value.toLowerCase();
            let rows = document.querySelectorAll("#memberTableBody tr");
            rows.forEach(row => {
                row.style.display = row.innerText.toLowerCase().includes(value) ? "" : "none";
            });
        });
    </script>
}