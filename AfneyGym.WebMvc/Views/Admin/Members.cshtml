@model List<User>
@{
    ViewData["Title"] = "Kullanıcı Yönetimi";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-uppercase">KULLANICI <span style="color:#e31e24">YÖNETİMİ</span></h2>
        <div class="d-flex gap-2">
            <input type="text" id="memberSearch" class="form-control bg-dark text-white border-secondary" placeholder="Kullanıcı ara...">
            @* REGRESSION CHECK: Ekleme butonu fonksiyonelliği korunuyor *@
            <button class="btn btn-primary"><i class="bi bi-person-plus"></i></button>
        </div>
    </div>

    <div class="card bg-dark border-secondary shadow">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-dark table-hover mb-0" id="membersTable">
                    <thead>
                        <tr class="border-bottom border-secondary">
                            <th class="ps-4">AD SOYAD</th>
                            <th>E-POSTA</th>
                            <th>ROL</th>
                            <th>KAYIT TARİHİ</th>
                            <th class="text-end pe-4">İŞLEMLER</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr class="align-middle border-bottom border-dark">
                                <td class="ps-4 fw-bold">@user.FirstName @user.LastName</td>
                                <td>@user.Email</td>
                                <td>
                                    @* MÜHENDİSLİK DÜZELTMESİ: Rol isimlendirmesi *@
                                    <span class="badge @(user.Role == 0 ? "bg-danger" : (int)user.Role == 1 ? "bg-warning" : "bg-secondary")">
                                        @(user.Role == 0 ? "Yönetici" : (int)user.Role == 1 ? "Personel" : "Üye")
                                    </span>
                                </td>
                                <td>@user.CreatedAt.ToString("dd.MM.yyyy")</td>
                                <td class="text-end pe-4">
                                    <button class="btn btn-outline-info btn-sm"><i class="bi bi-pencil"></i></button>
                                    <button class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i></button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>