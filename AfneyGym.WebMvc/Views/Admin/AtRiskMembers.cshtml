@using AfneyGym.Domain.Entities
@model List<User>
@{
    ViewData["Title"] = "Riskteki Uyeler";
}

<div class="space-y-4">
    <div>
        <h2 class="text-3xl font-black uppercase tracking-wide">RISKTEKI <span class="text-amber-300">UYELER</span></h2>
        <p class="mt-1 text-sm text-slate-400">Son aktivitelerine gore risk sinifina dusen uyeler.</p>
    </div>

    <div class="overflow-hidden rounded-2xl border border-slate-700/60 bg-panel shadow-2xl shadow-black/30">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-700/60 text-sm">
                <thead class="bg-panelSoft">
                    <tr class="text-left text-xs uppercase tracking-wide text-slate-400">
                        <th class="px-5 py-3">Ad Soyad</th>
                        <th class="px-5 py-3">E-posta</th>
                        <th class="px-5 py-3">Kayit Tarihi</th>
                        <th class="px-5 py-3 text-right">Aksiyon</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-800/70">
                    @if (!Model.Any())
                    {
                        <tr><td colspan="4" class="px-5 py-8 text-center text-slate-400">Riskte uye bulunmuyor.</td></tr>
                    }
                    @foreach (var member in Model)
                    {
                        <tr class="hover:bg-slate-800/40">
                            <td class="px-5 py-4 font-semibold text-white">@member.FirstName @member.LastName</td>
                            <td class="px-5 py-4 text-slate-300">@member.Email</td>
                            <td class="px-5 py-4 text-slate-400">@member.CreatedAt.ToString("dd.MM.yyyy")</td>
                            <td class="px-5 py-4 text-right">
                                <a asp-action="MemberDetail" asp-route-id="@member.Id" class="inline-flex rounded-lg border border-emerald-400/50 px-3 py-2 text-xs font-semibold text-emerald-300 hover:bg-emerald-500/10">Detay</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

