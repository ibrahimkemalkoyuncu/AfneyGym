@model AfneyGym.Domain.Entities.Lesson
@{
    ViewData["Title"] = "Yeni Ders Ekle";
}

<style>
    .bg-dark-input { background-color: #1a1a1a !important; border: 1px solid #333 !important; color: #fff !important; }
    .bg-dark-input:focus { border-color: #e31e24 !important; box-shadow: none !important; }
    label { color: #aaa; font-weight: 600; text-transform: uppercase; font-size: 0.8rem; margin-bottom: 8px; display: block; }
</style>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card bg-black border-secondary shadow-lg">
            <div class="card-header border-secondary py-3">
                <h4 class="fw-bold mb-0 text-white"><i class="bi bi-calendar-plus me-2 text-danger"></i> DERS <span class="text-danger">PLANLA</span></h4>
            </div>
            <div class="card-body p-4">
                <form asp-action="CreateLesson" method="post">
                    <div class="row">
                        <div class="col-md-12 mb-4">
                            <label asp-for="Name">DERS ADI / TİPİ</label>
                            <input asp-for="Name" class="form-control bg-dark-input" placeholder="Örn: Spinning, Yoga Başlangıç..." />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <label asp-for="TrainerId">EĞİTMEN SEÇİMİ</label>
                            <select asp-for="TrainerId" class="form-select bg-dark-input" asp-items="ViewBag.Trainers">
                                <option value="">Eğitmen Seçiniz...</option>
                            </select>
                            <span asp-validation-for="TrainerId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-4">
                            <label asp-for="GymId">ŞUBE / SALON</label>
                            <select asp-for="GymId" class="form-select bg-dark-input" asp-items="ViewBag.Gyms">
                                <option value="">Şube Seçiniz...</option>
                            </select>
                            <span asp-validation-for="GymId" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-4">
                            <label asp-for="StartTime">BAŞLANGIÇ SAATİ</label>
                            <input asp-for="StartTime" type="datetime-local" class="form-control bg-dark-input" />
                            <span asp-validation-for="StartTime" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4 mb-4">
                            <label asp-for="EndTime">BİTİŞ SAATİ</label>
                            <input asp-for="EndTime" type="datetime-local" class="form-control bg-dark-input" />
                            <span asp-validation-for="EndTime" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4 mb-4">
                            <label asp-for="Capacity">KONTENJAN (Kişi)</label>
                            <input asp-for="Capacity" type="number" class="form-control bg-dark-input" placeholder="Örn: 20" />
                            <span asp-validation-for="Capacity" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Description">DERS AÇIKLAMASI</label>
                        <textarea asp-for="Description" rows="3" class="form-control bg-dark-input" placeholder="Ders içeriği ve gereksinimler..."></textarea>
                    </div>

                    <div class="d-flex gap-2 pt-3">
                        <button type="submit" class="btn btn-danger px-5 fw-bold">DERSİ KAYDET</button>
                        <a asp-action="Lessons" class="btn btn-outline-secondary px-4">İPTAL</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
