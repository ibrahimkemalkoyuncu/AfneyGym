@model List<AfneyGym.Domain.Entities.Lesson>
@{
    ViewData["Title"] = "Ders Yönetimi";
}

<div>
    <div class="mb-5 flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
        <h2 class="text-3xl font-black uppercase tracking-wide">DERS <span class="text-accent">PROGRAMI</span></h2>
        <a asp-action="CreateLesson" class="inline-flex items-center gap-2 rounded-lg bg-accent px-4 py-2 text-sm font-semibold text-slate-900 hover:bg-sky-300">
            <i class="bi bi-calendar-plus"></i> YENİ DERS EKLE
        </a>
    </div>

    <div class="overflow-hidden rounded-2xl border border-slate-700/60 bg-panel shadow-2xl shadow-black/30">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-700/60 text-sm">
                <thead class="bg-panelSoft">
                    <tr class="text-left text-xs uppercase tracking-wide text-slate-400">
                        <th class="px-5 py-3">DERS ADI</th>
                        <th class="px-5 py-3">EĞİTMEN</th>
                        <th class="px-5 py-3">BAŞLANGIÇ</th>
                        <th class="px-5 py-3">SÜRE</th>
                        <th class="px-5 py-3">KONTENJAN</th>
                        <th class="px-5 py-3 text-right">İŞLEMLER</th>
                        </tr>
                    </thead>
                <tbody class="divide-y divide-slate-800/70">
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var lesson in Model)
                            {
                            <tr class="hover:bg-slate-800/40">
                                    <td class="px-5 py-4 font-semibold text-white">@lesson.Name</td>
                                    <td class="px-5 py-4 text-slate-300">@lesson.Trainer?.FullName</td>
                                    <td class="px-5 py-4 text-slate-300">@lesson.StartTime.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td class="px-5 py-4 text-slate-300">@((lesson.EndTime - lesson.StartTime).TotalMinutes) Dakika</td>
                                    <td class="px-5 py-4 text-slate-300">@lesson.Capacity Kişi</td>
                                    <td class="px-5 py-4 text-right">
                                        <button class="mr-1 inline-flex h-8 w-8 items-center justify-center rounded-lg border border-sky-400/50 text-sky-300 hover:bg-sky-500/10"><i class="bi bi-pencil"></i></button>
                                        <button class="inline-flex h-8 w-8 items-center justify-center rounded-lg border border-rose-400/50 text-rose-300 hover:bg-rose-500/10"><i class="bi bi-trash"></i></button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="px-5 py-8 text-center text-slate-400">Henüz ders programı oluşturulmadı.</td>
                            </tr>
                        }
                    </tbody>
            </table>
        </div>
    </div>
</div>