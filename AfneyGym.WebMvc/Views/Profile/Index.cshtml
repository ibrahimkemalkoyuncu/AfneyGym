@using AfneyGym.Domain.Entities
@model List<LessonAttendee>
@{
    ViewData["Title"] = "Profilim";
    var user = ViewBag.UserProfile as User;
}

<style>
    .profile-header { background: linear-gradient(135deg, #111, #222); border: 1px solid #333; border-radius: 20px; padding: 30px; margin-bottom: 30px; }
    .stat-card { background: #1a1a1a; border: 1px solid #333; border-radius: 15px; padding: 20px; text-align: center; }
    .lesson-item { background: #111; border: 1px solid #222; border-radius: 12px; margin-bottom: 15px; transition: 0.3s; }
    .lesson-item:hover { border-color: #0ea5e9; }
    .tab-btn.active { background: #0ea5e9; color: #0b1020; border-color: #0ea5e9; }
    .tab-pane { display: none; }
    .tab-pane.active { display: block; }
</style>

<div class="container">
    <div class="profile-header shadow-lg">
        <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
            <div class="flex items-center gap-4">
                <div class="flex h-20 w-20 items-center justify-center rounded-full bg-accent/20 text-accent">
                    <i class="bi bi-person-fill text-4xl"></i>
                </div>
                <div>
                    <h2 class="m-0 text-2xl font-black text-white">@user?.FirstName @user?.LastName</h2>
                    <p class="m-0 text-sm text-slate-400">@user?.Email | @(user?.Role == 0 ? "Yönetici" : "Üye")</p>
                    <span class="mt-2 inline-flex rounded-full border border-slate-600 px-3 py-1 text-xs text-slate-300">Şube: @(user?.Gym?.Name ?? "Genel Merkez")</span>
                </div>
            </div>
            <div class="text-right">
                <button class="inline-flex items-center rounded-lg border border-slate-500 px-3 py-2 text-sm text-slate-200 hover:bg-panelSoft"><i class="bi bi-pencil mr-2"></i>Bilgilerimi Güncelle</button>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 gap-4 md:grid-cols-12">
        <div class="md:col-span-4">
            <div class="stat-card mb-3 shadow-sm">
                <h6 class="text-xs uppercase tracking-wide text-slate-400">Antrenman Sayısı</h6>
                <h2 class="m-0 text-3xl font-black text-accent">@Model.Count</h2>
            </div>
            <div class="stat-card shadow-sm">
                <h6 class="text-xs uppercase tracking-wide text-slate-400">Hesap Durumu</h6>
                <h2 class="m-0 text-3xl font-black text-emerald-400">ONAYLI</h2>
            </div>
        </div>

        <div class="md:col-span-8">
            <div class="mb-4 flex gap-2" role="tablist">
                <button type="button" class="tab-btn active rounded-lg border border-slate-600 px-4 py-2 text-sm font-semibold text-slate-200" data-target="future">Gelecek Programım</button>
                <button type="button" class="tab-btn rounded-lg border border-slate-600 px-4 py-2 text-sm font-semibold text-slate-200" data-target="past">Geçmiş Antrenmanlar</button>
            </div>

            <div class="pt-2">
                <div class="tab-pane active" id="future">
                    @if (!Model.Any(la => la.Lesson.StartTime >= DateTime.Now))
                    {
                        <p class="italic text-slate-400">Henüz planlanmış bir dersiniz bulunmuyor.</p>
                    }
                    @foreach (var item in Model.Where(la => la.Lesson.StartTime >= DateTime.Now))
                    {
                        <div class="lesson-item p-3 shadow">
                            <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                                <div class="flex items-center gap-3">
                                    <div class="min-w-[60px] rounded border border-slate-700 bg-slate-900 p-2 text-center">
                                        <div class="font-bold text-accent">@item.Lesson.StartTime.ToString("dd")</div>
                                        <div class="text-xs uppercase text-slate-400">@item.Lesson.StartTime.ToString("MMM")</div>
                                    </div>
                                    <div>
                                        <h6 class="m-0 font-bold text-white">@item.Lesson.Name</h6>
                                        <small class="text-slate-400">Eğitmen: @item.Lesson.Trainer?.FullName</small>
                                    </div>
                                </div>
                                <div class="text-right">
                                    <div class="mb-2 font-bold text-slate-200">@item.Lesson.StartTime.ToString("HH:mm")</div>
                                    <form asp-controller="Home" asp-action="CancelJoin" method="post" onsubmit="return confirm('Bu dersten ayrılmak istediğinize emin misiniz?')">
                                        <input type="hidden" name="lessonId" value="@item.LessonId" />
                                        <button type="submit" class="inline-flex rounded-lg border border-rose-400/60 px-3 py-1 text-xs font-semibold text-rose-300 hover:bg-rose-500/10">İptal Et</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div class="tab-pane" id="past">
                    @foreach (var item in Model.Where(la => la.Lesson.StartTime < DateTime.Now))
                    {
                        <div class="lesson-item border-slate-700 p-3 opacity-60">
                             <div class="flex items-center justify-between">
                                <h6 class="m-0 font-bold text-white">@item.Lesson.Name</h6>
                                <span class="inline-flex rounded-full bg-emerald-500/20 px-3 py-1 text-xs font-semibold text-emerald-300">Tamamlandı</span>
                             </div>
                             <small class="text-slate-400">@item.Lesson.StartTime.ToString("dd MMMM yyyy")</small>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.tab-btn').forEach(button => {
            button.addEventListener('click', function () {
                const target = this.getAttribute('data-target');

                document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
                this.classList.add('active');

                document.querySelectorAll('.tab-pane').forEach(pane => pane.classList.remove('active'));
                document.getElementById(target).classList.add('active');
            });
        });
    </script>
}