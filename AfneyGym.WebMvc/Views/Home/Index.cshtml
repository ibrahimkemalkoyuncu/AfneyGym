@using AfneyGym.Domain.Entities
@using AfneyGym.Common.Enums
@model List<Lesson>

<div class="py-5">
    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-3">
        @foreach (var lesson in Model)
        {
            <div>
                <div class="h-full rounded-2xl border border-slate-700/60 bg-panel p-5 shadow-xl shadow-black/30">
                    <h5 class="text-lg font-black uppercase text-accent">@lesson.Name</h5>
                    <p class="mt-2 text-sm text-slate-400">@lesson.Description</p>
                    <div class="my-4 h-px bg-slate-700/70"></div>
                    <div class="mb-4 flex justify-between text-xs text-slate-300">
                        <span><i class="bi bi-person-badge mr-1"></i> @lesson.Trainer?.FullName</span>
                        <span><i class="bi bi-people mr-1"></i> @lesson.Attendees.Count / @lesson.Capacity</span>
                        </div>

                        @if (User.Identity.IsAuthenticated)
                        {
                            <form asp-controller="Home" asp-action="JoinLesson" method="post">
                                <input type="hidden" name="lessonId" value="@lesson.Id" />
                                
                                <button type="submit" class="inline-flex w-full items-center justify-center rounded-lg bg-accent px-4 py-3 text-sm font-bold text-slate-900 hover:bg-sky-300">
                                    DERSE KATIL
                                </button>
                            </form>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Login" class="inline-flex w-full items-center justify-center rounded-lg border border-slate-500 px-4 py-3 text-sm font-semibold text-slate-200 hover:bg-panelSoft">Giriş Yap ve Katıl</a>
                        }
                </div>
            </div>
        }
    </div>
</div>