@using AfneyGym.Domain.Entities
@using AfneyGym.Common.Enums
@model List<Lesson>

<div class="container py-5">
    <div class="row">
        @foreach (var lesson in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card bg-dark text-white border-secondary h-100 shadow">
                    <div class="card-body">
                        <h5 class="card-title fw-bold text-danger text-uppercase">@lesson.Name</h5>
                        <p class="small text-white-50">@lesson.Description</p>
                        <hr class="border-secondary">
                        <div class="d-flex justify-content-between small mb-3">
                            <span><i class="bi bi-person-badge me-1"></i> @lesson.Trainer?.FullName</span>
                            <span><i class="bi bi-people me-1"></i> @lesson.Attendees.Count / @lesson.Capacity</span>
                        </div>

                        @if (User.Identity.IsAuthenticated)
                        {
                            @* REGRESSION CHECK: Abonelik kontrolü UI tarafında yapılıyor *@
                            <form asp-controller="Home" asp-action="JoinLesson" method="post">
                                <input type="hidden" name="lessonId" value="@lesson.Id" />
                                
                                <button type="submit" class="btn btn-danger w-100 fw-bold shadow">
                                    DERSE KATIL
                                </button>
                            </form>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-light w-100">Giriş Yap ve Katıl</a>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>