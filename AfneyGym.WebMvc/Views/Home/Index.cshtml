@model AfneyGym.WebMvc.Models.HomeIndexViewModel
@{
    ViewData["Title"] = "Ana Sayfa";
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
}

<div class="pb-28">
<section class="relative overflow-hidden rounded-3xl border border-slate-700/60 bg-panel px-6 py-14 shadow-2xl shadow-black/30 md:px-12">
    <div class="absolute -right-20 -top-20 h-56 w-56 rounded-full bg-accent/15 blur-3xl"></div>
    <div class="absolute -bottom-20 -left-20 h-56 w-56 rounded-full bg-accent2/15 blur-3xl"></div>

    <div class="relative mx-auto max-w-4xl text-center">
        <span class="inline-flex rounded-full border border-accent/40 bg-accent/10 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-accent">Yeni Nesil Fitness Platformu</span>
        @if (Model.HeroVariant == "b")
        {
            <h1 class="mt-4 text-3xl font-black leading-tight text-white md:text-5xl">
                Program degil,
                <span class="text-accent">sonuc</span> odakli fitness deneyimi.
            </h1>
            <p class="mx-auto mt-4 max-w-2xl text-sm text-slate-300 md:text-base">
                Takvim, uyelik, bildirim ve odeme akislarini tek panelde yonet.
                Hedefine ulasana kadar surec her gun net ve olculebilir kalsin.
            </p>
        }
        else
        {
            <h1 class="mt-4 text-3xl font-black leading-tight text-white md:text-5xl">
                AfneyGym ile daha guclu, daha fit,
                <span class="text-accent">daha disiplinli</span> bir hayat.
            </h1>
            <p class="mx-auto mt-4 max-w-2xl text-sm text-slate-300 md:text-base">
                Ders rezervasyonu, uyelik yonetimi, odeme ve hatirlatma akislarini tek platformda topla.
                Hedefine ulasana kadar tum sureci biz sade tutariz.
            </p>
        }

        <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
            @if (isAuthenticated)
            {
                <a asp-controller="Home" asp-action="Lessons" class="inline-flex items-center justify-center rounded-lg bg-accent px-6 py-3 text-sm font-bold text-slate-900 shadow-glow hover:bg-sky-300">
                    Dersleri Gor
                </a>
            }
            else
            {
                <a asp-controller="Account" asp-action="Login" class="inline-flex items-center justify-center rounded-lg bg-accent px-6 py-3 text-sm font-bold text-slate-900 shadow-glow hover:bg-sky-300">
                    Giris Yap
                </a>
                <a asp-controller="Account" asp-action="Register" class="inline-flex items-center justify-center rounded-lg border border-slate-500 px-6 py-3 text-sm font-semibold text-slate-200 hover:bg-panelSoft">
                    Ucretsiz Kayit Ol
                </a>
            }
        </div>
    </div>
</section>

<section class="mt-8 grid grid-cols-1 gap-4 md:grid-cols-3">
    <div class="rounded-2xl border border-slate-700/60 bg-panel p-5">
        <h3 class="font-bold text-white">Akilli Ders Takvimi</h3>
        <p class="mt-2 text-sm text-slate-400">Kontenjan, cakisma ve kayit durumu tek ekranda net gorunur.</p>
    </div>
    <div class="rounded-2xl border border-slate-700/60 bg-panel p-5">
        <h3 class="font-bold text-white">Uyelik ve Odeme</h3>
        <p class="mt-2 text-sm text-slate-400">Manuel + iyzico akisini owner panelinden guvenli sekilde yonet.</p>
    </div>
    <div class="rounded-2xl border border-slate-700/60 bg-panel p-5">
        <h3 class="font-bold text-white">Anlik Bildirim</h3>
        <p class="mt-2 text-sm text-slate-400">E-posta ve web bildirimleri ile hicbir dersi kacirma.</p>
    </div>
</section>

<section id="paketler" class="mt-8 rounded-3xl border border-slate-700/60 bg-panel p-6 md:p-8">
    <div class="flex flex-col gap-2 md:flex-row md:items-end md:justify-between">
        <div>
            <h2 class="text-2xl font-black text-white">Paketler ve Fiyatlar</h2>
            <p class="text-sm text-slate-400">Ihtiyacina gore plan sec, istedigin zaman upgrade et.</p>
        </div>
        <a asp-controller="Subscription" asp-action="Index" class="text-sm text-accent hover:text-sky-300">Tum planlari incele</a>
    </div>

    <div class="mt-6 grid grid-cols-1 gap-4 lg:grid-cols-4">
        <article class="rounded-2xl border border-slate-700 bg-gymbg/40 p-5">
            <h3 class="text-sm font-semibold uppercase tracking-wide text-slate-300">Starter</h3>
            <p class="mt-2 text-2xl font-black text-white">1.200 TL<span class="text-sm font-medium text-slate-400"> / ay</span></p>
            <p class="mt-2 text-sm text-slate-400">Temel ekipman, grup dersleri, mobil takip.</p>
        </article>
        <article class="rounded-2xl border border-accent/40 bg-accent/10 p-5 shadow-glow">
            <p class="text-xs font-bold uppercase tracking-wide text-accent">En Cok Tercih Edilen</p>
            <h3 class="mt-2 text-sm font-semibold uppercase tracking-wide text-slate-200">Performance</h3>
            <p class="mt-2 text-2xl font-black text-white">3.300 TL<span class="text-sm font-medium text-slate-300"> / 3 ay</span></p>
            <p class="mt-2 text-sm text-slate-300">Akilli programlama + oncelikli ders rezervasyonu.</p>
        </article>
        <article class="rounded-2xl border border-slate-700 bg-gymbg/40 p-5">
            <h3 class="text-sm font-semibold uppercase tracking-wide text-slate-300">Pro</h3>
            <p class="mt-2 text-2xl font-black text-white">6.000 TL<span class="text-sm font-medium text-slate-400"> / 6 ay</span></p>
            <p class="mt-2 text-sm text-slate-400">Coach gorusmesi, ozel KPI takibi, sinirsiz rezervasyon.</p>
        </article>
        <article class="rounded-2xl border border-slate-700 bg-gymbg/40 p-5">
            <h3 class="text-sm font-semibold uppercase tracking-wide text-slate-300">Elite</h3>
            <p class="mt-2 text-2xl font-black text-white">10.800 TL<span class="text-sm font-medium text-slate-400"> / 12 ay</span></p>
            <p class="mt-2 text-sm text-slate-400">Tum premium avantajlar + owner tarafinda hizli destek.</p>
        </article>
    </div>
</section>

<section id="basari-hikayeleri" class="mt-8 rounded-3xl border border-slate-700/60 bg-panel p-6 md:p-8">
    <h2 class="text-2xl font-black text-white">Uyelerimizden Gercek Sonuclar</h2>
    <p class="mt-1 text-sm text-slate-400">Toplulugumuzdaki degisim hikayeleri ile motive ol.</p>

    <div class="mt-6 grid grid-cols-1 gap-4 lg:grid-cols-3">
        <blockquote class="rounded-2xl border border-slate-700 bg-gymbg/30 p-5">
            <p class="text-sm text-slate-200">"4 ayda 12 kg verdim. Ders planlama ve hatirlatmalar sayesinde hic kopmadim."</p>
            <footer class="mt-3 text-xs text-slate-400">- Ece K., Product Designer</footer>
        </blockquote>
        <blockquote class="rounded-2xl border border-slate-700 bg-gymbg/30 p-5">
            <p class="text-sm text-slate-200">"Cakisma kontrolu harika. Takvimim yogun olmasina ragmen hic ders kacirmiyorum."</p>
            <footer class="mt-3 text-xs text-slate-400">- Mert A., Software Engineer</footer>
        </blockquote>
        <blockquote class="rounded-2xl border border-slate-700 bg-gymbg/30 p-5">
            <p class="text-sm text-slate-200">"Uyelik ve odeme sureci net. Owner panelinden her sey cok hizli cozuluyor."</p>
            <footer class="mt-3 text-xs text-slate-400">- Zeynep T., HR Manager</footer>
        </blockquote>
    </div>

    <div class="mt-6 grid grid-cols-2 gap-4 text-center md:grid-cols-4">
        <div class="rounded-xl border border-slate-700 bg-gymbg/40 p-4"><p class="text-2xl font-black text-accent">@Model.Kpis.ActiveMembers</p><p class="text-xs text-slate-400">Aktif Uye</p></div>
        <div class="rounded-xl border border-slate-700 bg-gymbg/40 p-4"><p class="text-2xl font-black text-accent">@Model.Kpis.ActiveSubscriptions</p><p class="text-xs text-slate-400">Aktif Abonelik</p></div>
        <div class="rounded-xl border border-slate-700 bg-gymbg/40 p-4"><p class="text-2xl font-black text-accent">@Model.Kpis.CompletedLessons</p><p class="text-xs text-slate-400">Tamamlanan Ders</p></div>
        <div class="rounded-xl border border-slate-700 bg-gymbg/40 p-4"><p class="text-2xl font-black text-accent">@Model.Kpis.TotalTrainers</p><p class="text-xs text-slate-400">Toplam Egitmen</p></div>
    </div>
</section>
</div>

<div class="fixed bottom-4 left-1/2 z-40 w-[calc(100%-2rem)] max-w-3xl -translate-x-1/2 rounded-2xl border border-accent/40 bg-panel/95 p-3 shadow-2xl backdrop-blur-xl">
    <div class="flex flex-col items-center justify-between gap-3 sm:flex-row">
        <p class="text-center text-sm text-slate-200 sm:text-left">Hedefin hazirsa hemen basla. Programin sana gore otomatik sekillensin.</p>
        @if (isAuthenticated)
        {
            <a asp-controller="Home" asp-action="Lessons" class="inline-flex min-w-40 items-center justify-center rounded-lg bg-accent px-4 py-2 text-sm font-bold text-slate-900 hover:bg-sky-300">Derslere Git</a>
        }
        else
        {
            <a asp-controller="Account" asp-action="Login" class="inline-flex min-w-40 items-center justify-center rounded-lg bg-accent px-4 py-2 text-sm font-bold text-slate-900 hover:bg-sky-300">Hemen Giris Yap</a>
        }
    </div>
</div>

