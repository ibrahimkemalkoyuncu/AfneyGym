<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AfneyGym</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        gymbg: "#0b1020",
                        panel: "#121a2f",
                        panelSoft: "#1a2440",
                        accent: "#0ea5e9",
                        accent2: "#14b8a6"
                    },
                    boxShadow: {
                        glow: "0 10px 30px rgba(14,165,233,0.25)"
                    }
                }
            }
        };
    </script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
</head>
<body class="bg-gymbg text-slate-100 min-h-screen">
    <nav class="sticky top-0 z-20 border-b border-slate-700/50 bg-panel/90 px-6 py-4 backdrop-blur-xl">
        <div class="mx-auto flex max-w-7xl items-center justify-between">
            <div class="flex items-center gap-4">
                <a class="text-xl font-black tracking-wide" asp-controller="Home" asp-action="Index">AFNEY<span class="text-accent">GYM</span></a>
                <a asp-controller="Home" asp-action="Index" class="text-sm text-slate-300 hover:text-white">Ana Sayfa</a>
                <a asp-controller="Home" asp-action="Lessons" class="text-sm text-slate-300 hover:text-white">Dersler</a>
                @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Member"))
                {
                    <a asp-controller="Member" asp-action="Dashboard" class="text-sm text-slate-300 hover:text-white">Panelim</a>
                }
            </div>
            <div class="flex items-center gap-2">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <span class="mr-2 text-sm text-slate-300">Merhaba, @User.Identity.Name</span>
                    <a asp-controller="Account" asp-action="Logout" class="rounded-lg border border-rose-400/60 px-3 py-2 text-sm text-rose-300 hover:bg-rose-500/10">Çıkış</a>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="rounded-lg border border-slate-500 px-3 py-2 text-sm text-slate-200 hover:bg-panelSoft">Giriş Yap</a>
                    <a asp-controller="Account" asp-action="Register" class="rounded-lg bg-accent px-3 py-2 text-sm font-semibold text-slate-900 shadow-glow hover:bg-sky-300">Üye Ol</a>
                }
            </div>
        </div>
    </nav>

    <div class="mx-auto max-w-7xl px-4 py-6 md:px-8">
        @RenderBody()
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/preline@2.5.0/dist/preline.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script>
        @if (TempData["SuccessMessage"] != null)
        {
            <text>
            Swal.fire({
                icon: 'success',
                title: 'Başarılı!',
                text: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["SuccessMessage"]?.ToString())),
                background: '#121a2f',
                color: '#fff',
                confirmButtonColor: '#0ea5e9'
            });
            </text>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <text>
            Swal.fire({
                icon: 'error',
                title: 'Hata!',
                text: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["ErrorMessage"]?.ToString())),
                background: '#121a2f',
                color: '#fff',
                confirmButtonColor: '#0ea5e9'
            });
            </text>
        }

        if ('@User.Identity?.IsAuthenticated' === 'True') {
            const connection = new signalR.HubConnectionBuilder()
                .withUrl('/hubs/notifications')
                .withAutomaticReconnect()
                .build();

            connection.on('Notify', function (payload) {
                const title = payload?.title || 'Bildirim';
                const body = payload?.body || '';

                Swal.fire({
                    icon: 'info',
                    title: title,
                    text: body,
                    background: '#121a2f',
                    color: '#fff',
                    confirmButtonColor: '#0ea5e9'
                });

                if ('Notification' in window && Notification.permission === 'granted') {
                    new Notification(title, { body: body });
                }
            });

            if ('Notification' in window && Notification.permission === 'default') {
                Notification.requestPermission();
            }

            connection.start().catch(function () {
                // Web bildirim baglantisi kurulamazsa uygulama davranisi etkilenmesin.
            });
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>