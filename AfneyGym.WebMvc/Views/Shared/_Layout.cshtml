<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AfneyGym</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        gymbg: "#0b1020",
                        panel: "#121a2f",
                        panelSoft: "#1a2440",
                        accent: "#0ea5e9",
                        accent2: "#14b8a6"
                    },
                    boxShadow: {
                        glow: "0 10px 30px rgba(14,165,233,0.25)"
                    }
                }
            }
        };
    </script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
</head>
<body class="bg-gymbg text-slate-100 min-h-screen">

    @if (User.Identity.IsAuthenticated && User.IsInRole("Admin"))
    {
        <aside id="sidebar" class="fixed inset-y-0 left-0 z-30 w-72 border-r border-slate-700/50 bg-panel/95 backdrop-blur-xl transition-all duration-300">
            <div class="flex h-20 items-center justify-between border-b border-slate-700/40 px-6">
                <h1 class="text-xl font-black tracking-wide">AFNEY<span class="text-accent">GYM</span></h1>
                <button type="button" id="sidebarCollapse" class="rounded-lg border border-slate-600 px-2 py-1 text-slate-300 hover:bg-panelSoft">
                    <i class="bi bi-list"></i>
                </button>
            </div>
            <nav class="mt-4 px-3">
                <a class="mb-1 flex items-center gap-3 rounded-lg px-4 py-3 text-slate-300 hover:bg-panelSoft hover:text-white" asp-controller="Admin" asp-action="Dashboard"><i class="bi bi-speedometer2"></i><span>Dashboard</span></a>
                <a class="mb-1 flex items-center gap-3 rounded-lg px-4 py-3 text-slate-300 hover:bg-panelSoft hover:text-white" asp-controller="Admin" asp-action="Members"><i class="bi bi-people"></i><span>Kullanıcılar</span></a>
                <a class="mb-1 flex items-center gap-3 rounded-lg px-4 py-3 text-slate-300 hover:bg-panelSoft hover:text-white" asp-controller="Admin" asp-action="Trainers"><i class="bi bi-person-badge"></i><span>Eğitmenler</span></a>
                <a class="mb-1 flex items-center gap-3 rounded-lg px-4 py-3 text-slate-300 hover:bg-panelSoft hover:text-white" asp-controller="Admin" asp-action="Lessons"><i class="bi bi-calendar-event"></i><span>Dersler</span></a>
                <a class="mt-8 flex items-center gap-3 rounded-lg px-4 py-3 text-rose-300 hover:bg-rose-500/10" asp-controller="Account" asp-action="Logout"><i class="bi bi-box-arrow-right"></i><span>Çıkış</span></a>
            </nav>
        </aside>
    }

    <div id="content" class="min-h-screen transition-all duration-300 @(User.Identity.IsAuthenticated && User.IsInRole("Admin") ? "ml-72" : "ml-0")">
        @if (!User.IsInRole("Admin"))
        {
            <nav class="sticky top-0 z-20 border-b border-slate-700/50 bg-panel/90 px-6 py-4 backdrop-blur-xl">
                <div class="mx-auto flex max-w-7xl items-center justify-between">
                    <a class="text-xl font-black tracking-wide" asp-controller="Home" asp-action="Index">AFNEY<span class="text-accent">GYM</span></a>
                    <div class="flex items-center gap-2">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <span class="mr-2 text-sm text-slate-300">Merhaba, @User.Identity.Name</span>
                            <a asp-controller="Account" asp-action="Logout" class="rounded-lg border border-rose-400/60 px-3 py-2 text-sm text-rose-300 hover:bg-rose-500/10">Çıkış</a>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Login" class="rounded-lg border border-slate-500 px-3 py-2 text-sm text-slate-200 hover:bg-panelSoft">Giriş Yap</a>
                            <a asp-controller="Account" asp-action="Register" class="rounded-lg bg-accent px-3 py-2 text-sm font-semibold text-slate-900 shadow-glow hover:bg-sky-300">Üye Ol</a>
                        }
                    </div>
                </div>
            </nav>
        }

        <div class="mx-auto max-w-7xl px-4 py-6 md:px-8">
            @RenderBody()
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/preline@2.5.0/dist/preline.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function () {
            $('#sidebarCollapse').on('click', function () {
                const isCollapsed = $('#sidebar').toggleClass('w-20').hasClass('w-20');
                if (isCollapsed) {
                    $('#sidebar').removeClass('w-72');
                    $('#content').removeClass('ml-72').addClass('ml-20');
                } else {
                    $('#sidebar').removeClass('w-20').addClass('w-72');
                    $('#content').removeClass('ml-20').addClass('ml-72');
                }
            });

            @if (TempData["SuccessMessage"] != null)
            {
                <text>
                Swal.fire({
                    icon: 'success',
                    title: 'Başarılı!',
                    text: '@Html.Raw(TempData["SuccessMessage"])', 
                    background: '#121a2f',
                    color: '#fff',
                    confirmButtonColor: '#0ea5e9'
                });
                </text>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <text>
                Swal.fire({
                    icon: 'error',
                    title: 'Hata!',
                    text: '@Html.Raw(TempData["ErrorMessage"])',
                    background: '#121a2f',
                    color: '#fff',
                    confirmButtonColor: '#0ea5e9'
                });
                </text>
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>