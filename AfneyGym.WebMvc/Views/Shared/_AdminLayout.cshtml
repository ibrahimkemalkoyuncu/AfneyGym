<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AfneyGym Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        gymbg: "#0b1020",
                        panel: "#121a2f",
                        panelSoft: "#1a2440",
                        accent: "#0ea5e9"
                    }
                }
            }
        };
    </script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        :root { --sidebar-width: 260px; }
        body { background-color: #0b1020; color: #fff; }
        .sidebar { 
            width: var(--sidebar-width); 
            height: 100vh; 
            position: fixed; 
            background: #121a2f; 
            border-right: 1px solid rgba(148, 163, 184, 0.25);
            padding-top: 20px;
        }
        .nav-link { 
            color: #cbd5e1; 
            padding: 12px 25px; 
            display: flex; 
            align-items: center; 
            transition: 0.3s;
            border-left: 3px solid transparent;
        }
        .nav-link:hover, .nav-link.active { 
            color: #fff; 
            background: #1a2440; 
            border-left-color: #0ea5e9;
        }
        .nav-link i { margin-right: 15px; font-size: 1.2rem; }
        .main-content { margin-left: var(--sidebar-width); padding: 30px; max-width: 1200px; }
    </style>
</head>
<body class="bg-gymbg">

    <aside class="sidebar">
        <div class="mb-4 px-4">
            <h4 class="text-white"><span class="font-black text-accent">AFNEY</span><span class="font-black">GYM</span></h4>
            <small class="text-slate-400">Admin Kontrol Paneli</small>
        </div>

        <nav class="flex flex-col">
            <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Dashboard" ? "active" : "")" 
               asp-controller="Admin" asp-action="Dashboard">
                <i class="bi bi-speedometer2"></i> Dashboard
            </a>

            <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Subscription" ? "active" : "")" 
               asp-controller="Subscription" asp-action="ManageRequests">
                <i class="bi bi-credit-card"></i> Abonelik Talepleri
                @* Not: Buraya dinamik rakam ViewComponent ile eklenebilir *@
            </a>

            <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Members" ? "active" : "")" 
               asp-controller="Admin" asp-action="Members">
                <i class="bi bi-people"></i> Üye Yönetimi
            </a>

            <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Trainers" ? "active" : "")" 
               asp-controller="Admin" asp-action="Trainers">
                <i class="bi bi-person-badge"></i> Eğitmenler
            </a>

            <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Lessons" ? "active" : "")" 
               asp-controller="Admin" asp-action="Lessons">
                <i class="bi bi-calendar-event"></i> Ders Programı
            </a>

            <div class="mt-auto border-t border-slate-600 pt-2">
                <a class="nav-link text-rose-300" asp-controller="Account" asp-action="Logout">
                    <i class="bi bi-box-arrow-right"></i> Çıkış Yap
                </a>
            </div>
        </nav>
    </aside>

    <main class="main-content">
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/preline@2.5.0/dist/preline.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>