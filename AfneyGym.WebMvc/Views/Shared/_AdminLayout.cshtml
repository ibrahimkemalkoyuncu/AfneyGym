<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AfneyGym Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/admin.css" />
    <style>
        :root { --sidebar-width: 260px; --gym-red: #dc3545; }
        body { background-color: #0b0b0b; color: #fff; }
        .sidebar { 
            width: var(--sidebar-width); 
            height: 100vh; 
            position: fixed; 
            background: #111; 
            border-right: 1px solid #222;
            padding-top: 20px;
        }
        .nav-link { 
            color: #aaa; 
            padding: 12px 25px; 
            display: flex; 
            align-items: center; 
            transition: 0.3s;
            border-left: 3px solid transparent;
        }
        .nav-link:hover, .nav-link.active { 
            color: #fff; 
            background: #1a1a1a; 
            border-left-color: var(--gym-red);
        }
        .nav-link i { margin-right: 15px; font-size: 1.2rem; }
        .main-content { margin-left: var(--sidebar-width); padding: 30px; }
        .badge-pending { font-size: 0.7rem; padding: 3px 6px; }
    </style>
</head>
<body>

    <aside class="sidebar">
        <div class="px-4 mb-4">
            <h4 class="fw-bold text-white"><span class="text-danger">AFNEY</span>GYM</h4>
            <small class="text-white-50">Admin Kontrol Paneli</small>
        </div>

        <nav class="nav flex-column">
            <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Dashboard" ? "active" : "")" 
               asp-controller="Admin" asp-action="Dashboard">
                <i class="bi bi-speedometer2"></i> Dashboard
            </a>

            <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Subscription" ? "active" : "")" 
               asp-controller="Subscription" asp-action="ManageRequests">
                <i class="bi bi-credit-card"></i> Abonelik Talepleri
                @* Not: Buraya dinamik rakam ViewComponent ile eklenebilir *@
            </a>

            <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Members" ? "active" : "")" 
               asp-controller="Admin" asp-action="Members">
                <i class="bi bi-people"></i> Üye Yönetimi
            </a>

            <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Trainers" ? "active" : "")" 
               asp-controller="Admin" asp-action="Trainers">
                <i class="bi bi-person-badge"></i> Eğitmenler
            </a>

            <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Lessons" ? "active" : "")" 
               asp-controller="Admin" asp-action="Lessons">
                <i class="bi bi-calendar-event"></i> Ders Programı
            </a>

            <div class="mt-auto border-top border-secondary pt-2">
                <a class="nav-link text-danger" asp-controller="Account" asp-action="Logout">
                    <i class="bi bi-box-arrow-right"></i> Çıkış Yap
                </a>
            </div>
        </nav>
    </aside>

    <main class="main-content">
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>