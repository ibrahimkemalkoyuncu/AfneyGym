@using AfneyGym.Domain.Entities
@using AfneyGym.Common.Enums
@model List<Subscription>
@{
    ViewData["Title"] = "Abonelik Talepleri";
    Layout = "_AdminLayout";
}

<div>
    <div class="mb-5">
        <h2 class="text-3xl font-black uppercase tracking-wide">BEKLEYEN <span class="text-amber-300">TALEPLER</span></h2>
        <p class="mt-1 text-sm text-slate-400">Üyeler tarafından gönderilen ve onay bekleyen abonelik ödemeleri.</p>
    </div>

    <div class="overflow-hidden rounded-2xl border border-slate-700/60 bg-panel shadow-2xl shadow-black/30">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-700/60 text-sm">
                <thead class="bg-panelSoft">
                    <tr class="text-left text-xs uppercase tracking-wide text-slate-400">
                        <th class="px-5 py-3">ÜYE BİLGİSİ</th>
                        <th class="px-5 py-3">TALEP EDİLEN SÜRE</th>
                        <th class="px-5 py-3">TALEP TARİHİ</th>
                        <th class="px-5 py-3 text-right">İŞLEMLER</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-800/70">
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="px-5 py-8 text-center text-slate-400">Şu an onay bekleyen herhangi bir talep bulunmuyor.</td>
                        </tr>
                    }
                    @foreach (var sub in Model)
                    {
                        var durationMonths = (sub.EndDate.Year - sub.StartDate.Year) * 12 + sub.EndDate.Month - sub.StartDate.Month;
                        <tr class="hover:bg-slate-800/40">
                            <td class="px-5 py-4">
                                <div class="font-semibold text-white">@sub.User?.FirstName @sub.User?.LastName</div>
                                <div class="text-xs text-slate-400">@sub.User?.Email</div>
                            </td>
                            <td class="px-5 py-4"><span class="inline-flex rounded-full border border-amber-300/50 bg-amber-500/10 px-2 py-1 text-xs font-semibold text-amber-300">@durationMonths Ay</span></td>
                            <td class="px-5 py-4 text-slate-400">@sub.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                            <td class="px-5 py-4 text-right">
                                <form asp-action="Approve" method="post" class="inline-block">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@sub.Id" />
                                    <button type="submit" class="inline-flex items-center gap-1 rounded-lg bg-emerald-500 px-3 py-2 text-xs font-bold text-slate-900 hover:bg-emerald-400">
                                        <i class="bi bi-check-lg"></i> ONAYLA
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>