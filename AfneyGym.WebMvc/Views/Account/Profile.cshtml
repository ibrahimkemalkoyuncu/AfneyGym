@model AfneyGym.Common.DTOs.UserProfileDto
@{
    ViewData["Title"] = "Profilim";
}

<style>
    .profile-header { background: linear-gradient(45deg, #111, #222); border-radius: 20px; padding: 40px; border: 1px solid #333; margin-bottom: 30px; }
    .stat-box { background: #1a1a1a; border: 1px solid #333; border-radius: 15px; padding: 20px; text-align: center; }
    .history-card { background: #111; border: 1px solid #222; border-radius: 15px; overflow: hidden; }
</style>

<div class="container py-4">
    <div class="profile-header shadow-lg">
        <div class="row align-items-center">
            <div class="col-md-2 text-center">
                <div class="rounded-circle bg-danger d-inline-flex align-items-center justify-content-center" style="width: 100px; height: 100px;">
                    <span class="h1 m-0 text-white">@Model.FullName[0]</span>
                </div>
            </div>
            <div class="col-md-6">
                <h2 class="fw-bold text-white m-0">@Model.FullName</h2>
                <p class="text-white-50">@Model.Email | <span class="text-danger">@Model.GymName</span></p>
                @if (Model.SubscriptionEndDate.HasValue)
                {
                    <span class="badge bg-success">Abonelik: @Model.SubscriptionEndDate.Value.ToString("dd.MM.yyyy") tarihine kadar aktif</span>
                }
                else
                {
                    <span class="badge bg-warning text-dark">Aktif abonelik bulunamadı</span>
                }
            </div>
            <div class="col-md-4">
                <div class="stat-box">
                    <div class="small text-white-50 text-uppercase">Toplam Antrenman</div>
                    <div class="h2 fw-bold text-danger m-0">@Model.TotalAttendedLessons</div>
                </div>
            </div>
        </div>
    </div>

    <h4 class="fw-bold text-uppercase mb-4"><i class="bi bi-clock-history me-2 text-danger"></i>Katılım <span class="text-danger">Geçmişi</span></h4>

    <div class="history-card shadow">
        <div class="table-responsive">
            <table class="table table-dark table-hover mb-0">
                <thead>
                    <tr class="small text-white-50">
                        <th class="ps-4">DERS</th>
                        <th>EĞİTMEN</th>
                        <th>TARİH</th>
                        <th class="text-end pe-4">SAAT</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.AttendedLessons.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-white-50">Henüz bir derse katılım sağlamadınız.</td>
                        </tr>
                    }
                    @foreach (var item in Model.AttendedLessons)
                    {
                        <tr>
                            <td class="ps-4 fw-bold text-white">@item.LessonName</td>
                            <td class="text-white-50">@item.TrainerName</td>
                            <td class="small">@item.LessonDate.ToString("dd.MM.yyyy")</td>
                            <td class="text-end pe-4">
                                <span class="badge bg-dark border border-secondary">@item.TimeSlot</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>