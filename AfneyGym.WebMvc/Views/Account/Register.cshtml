@using AfneyGym.Common.DTOs
@model UserRegisterDto
@{
    ViewData["Title"] = "Üye Ol";
}

<style>
    .auth-card { background: #111; border: 1px solid #222; border-radius: 20px; padding: 40px; }
    .auth-input { background: #1a1a1a !important; border: 1px solid #333 !important; color: white !important; padding: 12px; }
    .auth-input:focus { border-color: #e31e24 !important; box-shadow: 0 0 0 0.25rem rgba(227, 30, 36, 0.1) !important; }
</style>

<div class="row justify-content-center align-items-center" style="min-height: 85vh;">
    <div class="col-md-6">
        <div class="auth-card shadow-lg">
            <div class="text-center mb-4">
                <h2 class="fw-bold text-white text-uppercase">Aramıza <span class="text-danger">Katıl</span></h2>
                <p class="text-white-50">Yeni bir başlangıç için formu doldur.</p>
            </div>

            <form asp-action="Register" method="post" asp-antiforgery="true">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="FirstName" class="form-label text-white-50 small text-uppercase">Ad</label>
                        <input asp-for="FirstName" class="form-control auth-input" />
                        <span asp-validation-for="FirstName" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="LastName" class="form-label text-white-50 small text-uppercase">Soyad</label>
                        <input asp-for="LastName" class="form-control auth-input" />
                        <span asp-validation-for="LastName" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label text-white-50 small text-uppercase">E-Posta Adresi</label>
                    <input asp-for="Email" class="form-control auth-input" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Password" class="form-label text-white-50 small text-uppercase">Şifre Oluştur</label>
                    <input asp-for="Password" type="password" class="form-control auth-input" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-danger w-100 fw-bold py-2 mb-3 shadow">KAYDI TAMAMLA</button>

                <div class="text-center">
                    <p class="text-white-50 small">Zaten üye misin? <a asp-action="Login" class="text-danger text-decoration-none fw-bold">Giriş Yap</a></p>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}