@using AfneyGym.Common.DTOs
@model UserLoginDto
@{
    ViewData["Title"] = "Giriş Yap";
}

<style>
    .auth-card { background: #111; border: 1px solid #222; border-radius: 20px; padding: 40px; }
    .auth-input { background: #1a1a1a !important; border: 1px solid #333 !important; color: white !important; padding: 12px; }
    .auth-input:focus { border-color: #e31e24 !important; box-shadow: 0 0 0 0.25rem rgba(227, 30, 36, 0.1) !important; }
</style>

<div class="row justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="col-md-5">
        <div class="auth-card shadow-lg">
            <div class="text-center mb-4">
                <h2 class="fw-bold text-white text-uppercase">Giriş <span class="text-danger">Yap</span></h2>
                <p class="text-white-50">Sınırlarını zorlamak için aramıza dön.</p>
            </div>

            <form asp-action="Login" method="post" asp-antiforgery="true">
                @* REGRESSION CHECK: Controller'dan gelen hata mesajları burada gösterilir *@
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label text-white-50 small text-uppercase">E-Posta</label>
                    <input asp-for="Email" class="form-control auth-input" placeholder="ornek@mail.com" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Password" class="form-label text-white-50 small text-uppercase">Şifre</label>
                    <input asp-for="Password" type="password" class="form-control auth-input" placeholder="••••••••" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-danger w-100 fw-bold py-2 mb-3 shadow">GİRİŞ YAP</button>

                <div class="text-center">
                    <p class="text-white-50 small">Hesabın yok mu? <a asp-action="Register" class="text-danger text-decoration-none fw-bold">Hemen Kayıt Ol</a></p>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}